# Production values - copy to values-prod.yaml and fill in
image:
  registry: <account-id>.dkr.ecr.<region>.amazonaws.com
  repository: temporalci
  tag: latest
  pullPolicy: Always

worker:
  replicas: 2
  resources:
    requests:
      cpu: 250m
      memory: 256Mi
    limits:
      cpu: "1"
      memory: 512Mi

webhook:
  replicas: 2
  resources:
    requests:
      cpu: 100m
      memory: 128Mi
    limits:
      cpu: 500m
      memory: 256Mi

temporal:
  enabled: true

postgresql:
  enabled: true
  auth:
    postgresPassword: <strong-password>
    database: temporal
  primary:
    persistence:
      storageClass: gp3

aws:
  region: <region>

secrets:
  prefix: temporalci
  local:
    enabled: false
  aws:
    enabled: true

serviceAccounts:
  worker:
    roleArn: arn:aws:iam::<account-id>:role/temporalci-worker
  webhook:
    roleArn: arn:aws:iam::<account-id>:role/temporalci-webhook
  ciJob:
    roleArn: arn:aws:iam::<account-id>:role/temporalci-ci-job
