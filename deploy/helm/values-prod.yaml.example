# Production values example - fill in with your environment-specific values
# NEVER commit real values to the repo

image:
  registry: "123456789.dkr.ecr.us-east-1.amazonaws.com"

aws:
  region: "us-east-1"

logs:
  s3Bucket: "my-temporalci-logs"

secrets:
  prefix: "temporalci"
  local:
    enabled: false
  aws:
    enabled: true

# In production, PostgreSQL is provided by RDS via ACK
postgresql:
  enabled: false

temporal:
  enabled: true

rds:
  enabled: true
  instanceClass: "db.t4g.micro"
  allocatedStorage: 20

s3:
  enabled: true

nodePool:
  system:
    enabled: true
  ciJobs:
    enabled: true

serviceAccounts:
  worker:
    roleArn: "arn:aws:iam::123456789:role/temporalci-worker"
  webhook:
    roleArn: "arn:aws:iam::123456789:role/temporalci-webhook"
  ciJob:
    roleArn: "arn:aws:iam::123456789:role/temporalci-ci-job"
