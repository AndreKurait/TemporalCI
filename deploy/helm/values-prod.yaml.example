# Production values example
# The actual deployed EKS configuration is in values-eks.yaml.
# To deploy with secrets:
#
#   helm upgrade --install temporalci deploy/helm \
#     -n temporalci --create-namespace \
#     -f deploy/helm/values.yaml \
#     -f deploy/helm/values-eks.yaml \
#     --set secrets.local.githubToken=ghp_xxx \
#     --set secrets.local.githubWebhookSecret=xxx
#
# Or use the bootstrap script:
#   GITHUB_TOKEN=ghp_xxx ./scripts/bootstrap.sh
